# TaskOps environment template.
# Copy to .env and fill in real values. Never commit the real .env.

# Environment name. Conventional Flask variable (development | production).
# Note: the application does not branch on this itself; it is provided for
# tooling and parity with common Flask setups.
FLASK_ENV=development

# Flask session signing key. REQUIRED in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me

# Path to the SQLite database file. In containers this is /data/taskops.db.
DATABASE_PATH=taskops.db

# Host port the app is published on (docker compose maps APP_PORT -> 5000).
APP_PORT=5000

# Maximum allowed task title length (consumed by the app).
MAX_TITLE_LENGTH=120
